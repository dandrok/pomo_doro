{
  "name": "pomo-doro-tui",
  "version": "1.13.0",
  "description": "pomodoro tui app",
  "license": "ISC",
  "author": "dandrok",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "pomo": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "pomodoro",
    "timer",
    "tui",
    "ink",
    "cli",
    "productivity"
  ],
  "scripts": {
    "dev": "tsx src/cli.tsx",
    "dev:test": "NODE_ENV=test tsx src/cli.tsx",
    "build": "tsup src/cli.tsx --format esm --clean --minify --target esnext",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run typecheck && npm run lint && npm run format:check"
  },
  "dependencies": {
    "conf": "^15.1.0",
    "ink": "^7.0.1",
    "ink-big-text": "^2.0.0",
    "ink-select-input": "^6.2.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.2.1",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.7"
  }
}
